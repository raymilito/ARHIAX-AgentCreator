# ARHIAX AgentCreator - Production Deployment Inputs
# Copy to .env in the deployment environment and replace every REQUIRED_AT_DEPLOY value.

ARHIAX_PRODUCTION=true

# Required secrets. Prefer Vault/secret manager injection; never commit real values.
AIM_HMAC_SECRET=REQUIRED_AT_DEPLOY_64_HEX_OR_VAULT
EVIDENCE_HMAC_SECRET=REQUIRED_AT_DEPLOY_64_HEX_OR_VAULT

# Optional Vault integration. If enabled, AIM reads arhiax/aim#hmac and Evidence reads arhiax/evidence#hmac.
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_MOUNT=secret

# Human approval notifications.
HIC_WEBHOOK_URL=
HIC_WEBHOOK_ALLOWED_HOSTS=

# Internal TLS/mTLS.
ARHIAX_CA_CERT=/certs/ca.crt
ARHIAX_TLS_VERIFY=true
ARHIAX_REQUIRE_MTLS=true

# Gateway security layer.
ARHIAX_REDIS_URL=redis://redis:6379/0
ARHIAX_REDIS_PREFIX=arhiax:gw
BROKER_JWKS_URL=https://credential-broker:8204/.well-known/jwks.json
BROKER_JWKS_REFRESH_SECONDS=300
GATEWAY_PUBLIC_URL=https://gateway:8080
DPOP_CLOCK_SKEW_SECONDS=60
EPHEMERAL_REPLAY_WINDOW_SECONDS=300
IDEMPOTENCY_TTL_SECONDS=86400

# Credential Broker.
BROKER_DEFAULT_TTL_SECONDS=60
BROKER_MAX_TTL_SECONDS=300
BROKER_REQUIRE_SIGNED_AGENT_PROOF=true
BROKER_AGENT_PROOF_MAX_SKEW_SECONDS=60
BROKER_SIGNING_KEY_PATH=/data/broker_signing_key.pem
BROKER_PERSIST_KEY=true

# SDK/runtime service URLs for production agents.
ARHIAX_GATEWAY_URL=https://gateway:8080
ARHIAX_AIM_URL=https://aim-service:8200
ARHIAX_HIC_URL=https://hic-service:8203
ARHIAX_BBR_URL=https://bbr-service:8202
ARHIAX_CREDENTIAL_BROKER_URL=https://credential-broker:8204
