# ══════════════════════════════════════════════════════════
# ARHIAX AgentCreator — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ══════════════════════════════════════════════════════════

# Secretos de seguridad (CAMBIA ESTOS EN PRODUCCIÓN)
AIM_HMAC_SECRET=arhiax-aim-secret-CHANGE-IN-PRODUCTION
EVIDENCE_HMAC_SECRET=arhiax-evidence-secret-CHANGE-IN-PRODUCTION

# HIC webhook — URL donde enviar notificaciones de aprobación humana
# Puede ser Slack, Teams, email gateway, etc.
# HIC_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Anthropic API Key (si tu agente usa Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Para el SDK (cuando el agente corre localmente)
ARHIAX_GATEWAY_URL=http://localhost:8080
ARHIAX_AIM_URL=http://localhost:8200
ARHIAX_HIC_URL=http://localhost:8203
ARHIAX_BBR_URL=http://localhost:8202
